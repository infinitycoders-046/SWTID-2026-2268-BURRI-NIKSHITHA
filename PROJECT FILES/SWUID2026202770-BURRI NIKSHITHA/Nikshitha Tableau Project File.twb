              <calculation class='tableau' formula='IF MONTH([Dates]) &lt;= 3 THEN&#13;&#10;&quot;After Lockdown&quot;&#13;&#10;ELSE&#13;&#10;&quot;Before Lockdown&quot;&#13;&#10;END' />
